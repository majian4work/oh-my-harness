#!/usr/bin/env -S just --justfile
# ^ A shebang isn't required, but allows a justfile to be executed
#   like a script, with `./justfile test`, for example.

set positional-arguments := true

workspace_root := justfile_directory()

# alias b := build

default:
    @just --justfile {{justfile()}} --list

docker-attach:
    cd {{workspace_root}} && ./devcontainer/bin/devcontainer.sh attach

# Build and run the TUI
omh *args:
    cargo run -r -p omh -- --log trace -c "$@"

test PROMPT="Parse this project and summarize its main components and functionality into test_summary.md":
    cargo run -r -p omh -- --log trace cli "{{PROMPT}}"

diagnose SESSION_ID:
    cargo run -r -p omh-dev -- diagnose "{{SESSION_ID}}"

omh-dev *args:
    cargo run -r -p omh-dev -- "$@"
